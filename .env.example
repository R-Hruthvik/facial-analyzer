# ============================================================================
# Facial Engagement Analyzer — Environment Configuration
# ============================================================================
# Copy this file to .env and adjust values for your environment.

# ---- Logging ---------------------------------------------------------------
LOG_LEVEL=INFO

# ---- MediaPipe Face Mesh ---------------------------------------------------
FACEMESH_MAX_NUM_FACES=1
FACEMESH_MIN_DETECTION_CONFIDENCE=0.5
FACEMESH_MIN_TRACKING_CONFIDENCE=0.5

# ---- Camera / Video --------------------------------------------------------
CAMERA_ID=0
FRAME_WIDTH=640
FRAME_HEIGHT=480
FRAME_SKIP=2              # Process every 3rd frame
RESIZE_SCALE=0.75         # Downscale to 75% before inference

# ---- EAR Thresholds --------------------------------------------------------
EAR_THRESHOLD=0.20
EAR_CONSECUTIVE_FRAMES=3

# ---- MAR Thresholds --------------------------------------------------------
MAR_THRESHOLD=0.6

# ---- Head Pose Thresholds (degrees) ----------------------------------------
HEAD_PITCH_THRESHOLD=20.0
HEAD_YAW_THRESHOLD=25.0
HEAD_ROLL_THRESHOLD=30.0

# ---- Server Ports ----------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
DASHBOARD_PORT=8501
